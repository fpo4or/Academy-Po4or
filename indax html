          </p>
        </header>

        <form class="registration-form" id="registrationForm">
          <div class="form-group">
            <label for="firstname">Prénom</label>
            <input id="firstname" name="firstname" type="text" required>
          </div>

          <div class="form-group">
            <label for="lastname">Nom</label>
            <input id="lastname" name="lastname" type="text" required>
          </div>

          <div class="form-group">
            <label for="email">Adresse e-mail</label>
            <input id="email" name="email" type="email" required>
          </div>

          <div class="form-group">
            <label for="programme">Programme souhaité</label>
            <select id="programme" name="programme" required>
              <option value="">Sélectionner</option>
              <option>Médias culturels</option>
              <option>Cinéma court</option>
              <option>Création numérique</option>
              <option>Écriture et narration</option>
              <option>Production audiovisuelle</option>
              <option>Ateliers artistiques</option>
            </select>
          </div>

          <div class="form-group full">
            <label for="message">Votre projet ou votre motivation</label>
            <textarea
              id="message"
              name="message"
              placeholder="Présentez-vous en quelques lignes"
            ></textarea>
          </div>

          <div class="form-group full">
            <button class="button button-primary" type="submit">
              Envoyer la préinscription
