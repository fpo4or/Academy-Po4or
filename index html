<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <meta
    name="description"
    content="PO4OR Académie — Formations, ateliers et programmes culturels de l'association Portail de l'Orient."
  >

  <title>PO4OR Académie | Portail de l’Orient</title>

  <style>
    :root {
      --red: #ed1c24;
      --blue: #174a7e;
      --blue-dark: #0c3158;
      --gold: #b38a32;
      --gold-light: #d5b568;
      --grey: #666b72;
      --grey-dark: #30343a;
      --grey-light: #f1f3f5;
      --white: #ffffff;
      --border: #e2e5e8;
      --shadow: 0 18px 45px rgba(20, 40, 60, 0.10);
      --radius: 20px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      color: var(--grey-dark);
      background: var(--white);
      line-height: 1.65;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    .container {
      width: min(1180px, calc(100% - 40px));
      margin: 0 auto;
    }

    /* Barre supérieure */

    .topbar {
      background: var(--blue-dark);
      color: var(--white);
      font-size: 13px;
    }

    .topbar-inner {
      min-height: 38px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
    }

    .topbar a {
      opacity: 0.9;
    }

    .topbar a:hover {
      opacity: 1;
      color: var(--gold-light);
    }

    /* Navigation */

    .site-header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255, 255, 255, 0.97);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(12px);
    }

    .nav-inner {
      min-height: 100px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 30px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .brand-logo {
      width: 170px;
      height: auto;
    }

    .brand-academy {
      padding-left: 16px;
      border-left: 1px solid var(--gold);
    }

    .brand-academy strong {
      display: block;
      color: var(--gold);
      font-size: 17px;
      letter-spacing: 0.28em;
      font-weight: 700;
    }

    .brand-academy span {
      color: var(--grey);
      font-size: 11px;
      letter-spacing: 0.05em;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 24px;
      list-style: none;
      font-size: 14px;
      font-weight: 700;
    }

    .nav-links a {
      position: relative;
      padding: 12px 0;
    }

    .nav-links a::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: 5px;
      width: 0;
      height: 2px;
      background: var(--red);
      transition: width 0.25s ease;
    }

    .nav-links a:hover::after {
      width: 100%;
    }

    .nav-cta {
      padding: 13px 20px !important;
      border-radius: 999px;
      color: var(--white);
      background: var(--red);
      box-shadow: 0 10px 25px rgba(237, 28, 36, 0.22);
    }

    .nav-cta::after {
      display: none;
    }

    .nav-cta:hover {
      background: #c9151c;
    }

    .menu-button {
      display: none;
      border: 0;
      background: transparent;
      font-size: 28px;
      color: var(--blue-dark);
      cursor: pointer;
    }

    /* Hero */

    .hero {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at 84% 20%, rgba(179, 138, 50, 0.18), transparent 28%),
        linear-gradient(135deg, #ffffff 0%, #f5f8fb 62%, #eef2f5 100%);
      border-bottom: 1px solid var(--border);
    }

    .hero::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 8px;
      height: 100%;
      background: linear-gradient(
        to bottom,
        var(--red) 0 34%,
        var(--gold) 34% 67%,
        var(--blue) 67% 100%
      );
    }

    .hero-inner {
      min-height: 670px;
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      align-items: center;
      gap: 70px;
      padding: 80px 0;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 22px;
      color: var(--blue);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .eyebrow::before {
      content: "";
      width: 36px;
      height: 3px;
      background: var(--gold);
    }

    .hero h1 {
      color: var(--blue-dark);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(52px, 7vw, 92px);
      font-weight: 400;
      line-height: 0.96;
      letter-spacing: -0.04em;
    }

    .hero h1 span {
      display: block;
      margin-top: 12px;
      color: var(--red);
      font-family: Arial, Helvetica, sans-serif;
      font-size: 0.28em;
      font-weight: 800;
      letter-spacing: 0.35em;
      text-transform: uppercase;
    }

    .hero-text {
      max-width: 680px;
      margin-top: 30px;
      color: var(--grey);
      font-size: 19px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 34px;
    }

    .button {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-height: 52px;
      padding: 0 25px;
      border: 1px solid transparent;
      border-radius: 999px;
      font-weight: 800;
      transition: all 0.25s ease;
      cursor: pointer;
    }

    .button-primary {
      color: var(--white);
      background: var(--red);
      box-shadow: 0 12px 30px rgba(237, 28, 36, 0.20);
    }

    .button-primary:hover {
      background: #c9151c;
      transform: translateY(-2px);
    }

    .button-secondary {
      color: var(--blue);
      background: var(--white);
      border-color: var(--blue);
    }

    .button-secondary:hover {
      color: var(--white);
      background: var(--blue);
      transform: translateY(-2px);
    }

    .hero-card {
      position: relative;
      padding: 38px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 30px;
      box-shadow: var(--shadow);
    }

    .hero-card::before {
      content: "";
      position: absolute;
      top: -1px;
      left: 38px;
      width: 90px;
      height: 5px;
      background: var(--gold);
    }

    .hero-card-label {
      color: var(--red);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .hero-card h2 {
      margin: 16px 0;
      color: var(--blue-dark);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 31px;
      line-height: 1.2;
    }

    .hero-card p {
      color: var(--grey);
    }

    .hero-card-list {
      margin-top: 24px;
      list-style: none;
    }

    .hero-card-list li {
      display: flex;
      gap: 12px;
      padding: 13px 0;
      border-bottom: 1px solid var(--border);
    }

    .hero-card-list li:last-child {
      border-bottom: 0;
    }

    .hero-card-list li::before {
      content: "•";
      color: var(--gold);
      font-size: 26px;
      line-height: 20px;
    }

    /* Sections générales */

    section {
      padding: 100px 0;
    }

    .section-soft {
      background: var(--grey-light);
    }

    .section-header {
      max-width: 760px;
      margin-bottom: 48px;
    }

    .section-kicker {
      display: block;
      margin-bottom: 10px;
      color: var(--red);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .section-title {
      color: var(--blue-dark);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(38px, 5vw, 59px);
      font-weight: 400;
      line-height: 1.1;
    }

    .section-description {
      margin-top: 18px;
      color: var(--grey);
      font-size: 18px;
    }

    /* Programmes */

    .programmes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .programme-card {
      position: relative;
      min-height: 320px;
      padding: 30px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .programme-card:hover {
      transform: translateY(-7px);
      box-shadow: var(--shadow);
    }

    .programme-card::after {
      content: "";
      position: absolute;
      right: -35px;
      bottom: -35px;
      width: 110px;
      height: 110px;
      border: 22px solid rgba(23, 74, 126, 0.07);
      border-radius: 50%;
    }

    .programme-number {
      color: var(--gold);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.16em;
    }

    .programme-card h3 {
      margin: 24px 0 14px;
      color: var(--blue);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 28px;
      line-height: 1.2;
    }

    .programme-card p {
      color: var(--grey);
    }

    .programme-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 24px;
    }

    .programme-meta span {
      padding: 7px 11px;
      color: var(--grey-dark);
      background: var(--grey-light);
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
    }

    /* Mission */

    .mission-grid {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: 70px;
      align-items: center;
    }

    .mission-panel {
      padding: 46px;
      color: var(--white);
      background: var(--blue-dark);
      border-radius: 28px;
      box-shadow: var(--shadow);
    }

    .mission-panel strong {
      display: block;
      margin-bottom: 18px;
      color: var(--gold-light);
      font-size: 14px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .mission-panel p {
      font-family: Georgia, "Times New Roman", serif;
      font-size: 29px;
      line-height: 1.45;
    }

    .mission-list {
      display: grid;
      gap: 20px;
    }

    .mission-item {
      display: grid;
      grid-template-columns: 54px 1fr;
      gap: 18px;
      padding: 22px 0;
      border-bottom: 1px solid var(--border);
    }

    .mission-item:last-child {
      border-bottom: 0;
    }

    .mission-icon {
      width: 54px;
      height: 54px;
      display: grid;
      place-items: center;
      color: var(--white);
      background: var(--red);
      border-radius: 16px;
      font-weight: 800;
    }

    .mission-item h3 {
      color: var(--blue);
      font-size: 19px;
    }

    .mission-item p {
      margin-top: 6px;
      color: var(--grey);
    }

    /* Publics */

    .audience-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
    }

    .audience-card {
      padding: 25px 17px;
      text-align: center;
      background: var(--white);
      border-top: 4px solid var(--gold);
      border-radius: 14px;
      box-shadow: 0 10px 28px rgba(35, 50, 65, 0.07);
    }

    .audience-card strong {
      display: block;
      color: var(--blue-dark);
      font-size: 16px;
    }

    /* Inscription */

    .registration {
      position: relative;
      color: var(--white);
      background:
        linear-gradient(110deg, rgba(12, 49, 88, 0.98), rgba(23, 74, 126, 0.94));
      overflow: hidden;
    }

    .registration::after {
      content: "";
      position: absolute;
      top: -150px;
      right: -120px;
      width: 420px;
      height: 420px;
      border: 70px solid rgba(255, 255, 255, 0.06);
      border-radius: 50%;
    }

    .registration-grid {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 0.8fr 1.2fr;
      gap: 70px;
      align-items: start;
    }

    .registration .section-kicker {
      color: var(--gold-light);
    }

    .registration .section-title,
    .registration .section-description {
      color: var(--white);
    }

    .registration-form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      padding: 32px;
      color: var(--grey-dark);
      background: var(--white);
      border-radius: 24px;
      box-shadow: var(--shadow);
    }

    .form-group {
      display: grid;
      gap: 7px;
    }

    .form-group.full {
      grid-column: 1 / -1;
    }

    .form-group label {
      color: var(--blue-dark);
      font-size: 13px;
      font-weight: 800;
    }

